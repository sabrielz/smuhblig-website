# ============================================================
# SMK Muhammadiyah Bligo — Production Environment Variables
# ============================================================
# PENTING: File ini hanya berisi KEY dan deskripsi.
# JANGAN isi nilai sensitif di sini.
# Salin file ini menjadi .env di server production dan isi setiap value.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME="SMK Muhammadiyah Bligo"
APP_ENV=production
APP_KEY=                          # Generate via: php artisan key:generate
APP_DEBUG=false                   # WAJIB false di production
APP_URL=https://smkmuhbligo.sch.id
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_AVAILABLE_LOCALES=id,en

# ------------------------------------------------------------
# Maintenance Mode
# ------------------------------------------------------------
APP_MAINTENANCE_DRIVER=file

# ------------------------------------------------------------
# PHP CLI
# ------------------------------------------------------------
PHP_CLI_SERVER_WORKERS=4

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
BCRYPT_ROUNDS=12                  # Minimal 12 untuk production (12-14 recommended)

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                   # Gunakan 'error' di production, bukan 'debug'

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=                          # IP/hostname PostgreSQL server
DB_PORT=5432
DB_DATABASE=                      # Nama database production
DB_USERNAME=                      # User database (bukan superuser)
DB_PASSWORD=                      # Password kuat, min 32 karakter

# ------------------------------------------------------------
# Broadcasting
# ------------------------------------------------------------
BROADCAST_CONNECTION=log

# ------------------------------------------------------------
# Filesystem
# ------------------------------------------------------------
FILESYSTEM_DISK=local

# ------------------------------------------------------------
# Queue (Redis)
# ------------------------------------------------------------
QUEUE_CONNECTION=redis

# ------------------------------------------------------------
# Session (Redis for production — tidak hilang saat server restart)
# ------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true        # WAJIB true jika menggunakan HTTPS
SESSION_SAME_SITE=lax

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=                       # IP/hostname Redis server (jangan expose public)
REDIS_PASSWORD=                   # Password Redis (wajib di production)
REDIS_PORT=6379

# ------------------------------------------------------------
# Cache (Redis)
# ------------------------------------------------------------
CACHE_STORE=redis
CACHE_PREFIX=smkmuhbligo_

# ------------------------------------------------------------
# Mail (SMTP Production)
# ------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=                        # SMTP server hostname (misalnya: smtp.gmail.com)
MAIL_PORT=587                     # 587 untuk TLS, 465 untuk SSL
MAIL_USERNAME=                    # Email address pengirim
MAIL_PASSWORD=                    # Password atau App Password SMTP
MAIL_ENCRYPTION=tls               # tls atau ssl
MAIL_FROM_ADDRESS="noreply@smkmuhbligo.sch.id"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------
# Vite (Frontend Build)
# ------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------
# AI APIs
# ------------------------------------------------------------
ANTHROPIC_API_KEY=                # sk-ant-... (dari console.anthropic.com)
ANTHROPIC_MODEL=claude-opus-4-5
AI_MAX_TOKENS=4096
AI_QUEUE_CONNECTION=redis
AI_RATE_LIMIT_PER_MINUTE=20       # Max AI requests per user per menit

OPENAI_API_KEY=                   # sk-... (opsional, jika pakai OpenAI)
OPENAI_ORGANIZATION=              # Org ID OpenAI (opsional)

# ------------------------------------------------------------
# SEO (opsional)
# ------------------------------------------------------------
# GOOGLE_ANALYTICS_ID=            # G-XXXXXXXXXX
# GOOGLE_SEARCH_CONSOLE_KEY=      # Kode verifikasi Google Search Console

# ------------------------------------------------------------
# Backup (jika menggunakan spatie/laravel-backup)
# ------------------------------------------------------------
# BACKUP_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
